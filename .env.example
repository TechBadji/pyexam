# ── Environnement ─────────────────────────────────────────────────────────────
# "development" → active le seed, affiche les docs API (/api/docs)
# "production"  → désactive le seed et les docs API
ENV=production

# ── Base de données ────────────────────────────────────────────────────────────
# Railway plugin PostgreSQL — fourni automatiquement
POSTGRES_USER=pyexam
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=pyexam
DATABASE_URL=postgresql+asyncpg://pyexam:change-this-strong-password@postgres:5432/pyexam

# ── Redis ──────────────────────────────────────────────────────────────────────
# Railway plugin Redis — fourni automatiquement
REDIS_URL=redis://redis:6379/0

# ── Sécurité JWT ───────────────────────────────────────────────────────────────
# Obligatoire — générer avec: python -c "import secrets; print(secrets.token_hex(32))"
# Minimum 32 caractères
SECRET_KEY=change-this-to-a-long-random-string-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Emails transactionnels (Resend.com) ────────────────────────────────────────
# Laisser "re_placeholder" en développement pour voir le code dans la réponse API
RESEND_API_KEY=re_your_resend_key_here
FROM_EMAIL=exams@yourdomain.com

# ── Paramètres plateforme ──────────────────────────────────────────────────────
INSTITUTION_NAME=Université PyExam
PASSING_GRADE_PERCENT=50

# ── Services internes ──────────────────────────────────────────────────────────
# Railway: remplacer par l'URL interne du service Piston
PISTON_API_URL=http://piston:2000

# ── URL publique du frontend ───────────────────────────────────────────────────
# Railway: remplacer par l'URL Railway générée (ex: https://pyexam.up.railway.app)
# Utilisée pour la politique CORS du backend
FRONTEND_URL=https://your-app.up.railway.app
