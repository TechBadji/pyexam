# ── Base de données (Railway plugin PostgreSQL — fourni automatiquement)
DATABASE_URL=postgresql+asyncpg://pyexam:pyexam@localhost:5432/pyexam

# ── Redis (Railway plugin Redis — fourni automatiquement)
REDIS_URL=redis://localhost:6379/0

# ── Sécurité JWT (obligatoire — générer avec: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-this-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Emails transactionnels (Resend.com — compte gratuit)
RESEND_API_KEY=re_your_resend_key_here
FROM_EMAIL=exams@yourdomain.com

# ── Paramètres plateforme
INSTITUTION_NAME=Université PyExam
PASSING_GRADE_PERCENT=50

# ── Services internes (Railway: remplacer par l'URL interne du service Piston)
PISTON_API_URL=http://piston:2000

# ── URL publique du frontend (Railway: remplacer par l'URL Railway générée)
FRONTEND_URL=https://pyexam-frontend.up.railway.app
